# ──────────────────────────────────────────────
# Sentry 설정
# https://sentry.io 에서 프로젝트를 생성한 뒤 아래 값을 채워주세요
# ──────────────────────────────────────────────

# Sentry DSN (클라이언트 + 서버 공용)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry 조직/프로젝트 (소스맵 업로드 시 필요)
SENTRY_ORG=
SENTRY_PROJECT=

# Sentry Auth Token (소스맵 업로드 시 필요)
SENTRY_AUTH_TOKEN=
